# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
build/
.next/
out/

# ─── Environment & secrets — NEVER commit these ───────────────────────────────
.env
.env.local
.env.*.local
*.env

# ─── Prisma generated client (regenerated on install) ─────────────────────────
vairiot-api/src/generated/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ─── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.swp

# ─── Android build output ─────────────────────────────────────────────────────
vairiot-mobile/.gradle/
vairiot-mobile/build/
vairiot-mobile/app/build/
vairiot-mobile/local.properties
vairiot-mobile/*.keystore
vairiot-mobile/*.jks

# ─── Test coverage ────────────────────────────────────────────────────────────
coverage/

# ─── Docker ───────────────────────────────────────────────────────────────────
infra/data/

# ─── Local tooling (Claude Code, ClaudeFlow) — per-machine, never commit ──────
.claude/
.claude-flow/
**/.claude-flow/

# ─── Design working files (e.g. Inkscape numbered drafts) ─────────────────────
vairiot-admin/public/favicon[0-9]*.svg
