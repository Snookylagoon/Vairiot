generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────
enum DeploymentMode {
  standalone
  saas
  hybrid
}

enum LicenceStatus {
  active
  expiring
  expired
  suspended
  revoked
}

enum LicenceTierName {
  FREE
  TIER_2
  TIER_3
}

enum OnboardingStep {
  user_registration
  company_registration
  client_registration
  licence_activation
}

// ─── Tenants ──────────────────────────────────────────────────────────────────
model Tenant {
  id               String         @id @default(cuid())
  name             String         @unique
  plan             String         @default("standalone")
  deploymentMode   DeploymentMode @default(standalone)
  onboardingComplete Boolean      @default(false)
  active           Boolean        @default(true)
  parentTenantId   String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  parentTenant       Tenant?        @relation("TenantChildren", fields: [parentTenantId], references: [id])
  childTenants       Tenant[]       @relation("TenantChildren")
  users              User[]
  roles              Role[]
  auditEvents        AuditEvent[]
  categories         Category[]
  sites              Site[]
  assets             Asset[]
  auditCampaigns     AuditCampaign[]
  checkouts          Checkout[]
  apiKeys            ApiKey[]
  licences           Licence[]
  devices            Device[]
  featureFlags       Json           @default("{}")
  company            Company?
  clientCompanies    ClientCompany[]
  onboardingProgress OnboardingProgress[]

  @@index([parentTenantId])
  @@map("tenants")
}

// ─── API Keys ─────────────────────────────────────────────────────────────────
model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  prefix     String
  hash       String
  scopes     String[]
  createdBy  String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([prefix])
  @@map("api_keys")
}

// ─── Users ────────────────────────────────────────────────────────────────────
model User {
  id               String    @id @default(cuid())
  tenantId         String
  email            String
  name             String
  phone            String?
  passwordHash     String?
  active           Boolean   @default(true)
  twoFactorEnabled Boolean   @default(false)
  mustChangePassword Boolean  @default(false)
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  roles         UserRole[]
  auditEvents   AuditEvent[]
  twoFactor     UserTwoFactor?
  loginAttempts LoginAttempt[]
  invitations   UserInvitation[]
  devices       Device[]
  permissionOverrides UserPermissionOverride[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("users")
}

// ─── Roles ────────────────────────────────────────────────────────────────────
model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  permissions String[]
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id])
  users  UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model UserPermissionOverride {
  userId     String
  permission String
  granted    Boolean
  grantedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permission])
  @@index([userId])
  @@map("user_permission_overrides")
}

model UserRole {
  userId    String
  roleId    String
  grantedAt DateTime @default(now())
  grantedBy String?

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

// ─── Audit Events ─────────────────────────────────────────────────────────────
model AuditEvent {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String?
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  metadata   Json?
  occurredAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  actor  User?  @relation(fields: [actorId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, occurredAt])
  @@map("audit_events")
}

// ─── Asset Categories ─────────────────────────────────────────────────────────
model Category {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  parentId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  assets   Asset[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([parentId])
  @@map("categories")
}

// ─── Sites & Locations ────────────────────────────────────────────────────────
model Site {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  city      String?
  country   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  locations Location[]
  assets    Asset[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("sites")
}

model Location {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  type      String   @default("room")
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site     Site       @relation(fields: [siteId], references: [id])
  parent   Location?  @relation("LocationChildren", fields: [parentId], references: [id])
  children Location[] @relation("LocationChildren")
  assets   Asset[]

  @@index([siteId])
  @@index([parentId])
  @@map("locations")
}

// ─── Assets ───────────────────────────────────────────────────────────────────
model Asset {
  id           String    @id @default(cuid())
  tenantId     String
  assetNumber  String
  name         String
  description  String?
  categoryId   String?
  siteId       String?
  locationId   String?
  status       String    @default("active")
  condition    String    @default("good")
  serialNumber String?
  modelNumber  String?
  manufacturer String?
  barcode      String?
  rfidTag      String?

  // ── Financial: Procurement ──
  purchaseDate       DateTime?
  purchaseCost       Decimal?  @db.Decimal(12, 2)
  supplier           String?
  purchaseOrderNumber String?
  invoiceNumber      String?
  invoiceDate        DateTime?
  receiptDate        DateTime?
  capitalizationDate DateTime?

  // ── Financial: Cost Components ──
  freightCost        Decimal?  @db.Decimal(12, 2)
  installationCost   Decimal?  @db.Decimal(12, 2)
  customsDuties      Decimal?  @db.Decimal(12, 2)
  otherCapitalizedCosts Decimal? @db.Decimal(12, 2)

  // ── Financial: Valuation ──
  residualValue      Decimal?  @db.Decimal(12, 2)

  // ── Depreciation ──
  depreciationMethod String?   @default("straight_line")
  usefulLifeMonths   Int?
  depreciationStartDate DateTime?

  warrantyExpiry DateTime?
  notes        String?
  customFields Json?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  category  Category?  @relation(fields: [categoryId], references: [id])
  site      Site?      @relation(fields: [siteId], references: [id])
  location  Location?  @relation(fields: [locationId], references: [id])
  checkouts         Checkout[]
  photos            Photo[]
  disposal          Disposal?
  documents         Document[]
  maintenanceEvents MaintenanceEvent[]
  transfers         Transfer[]

  @@unique([tenantId, assetNumber])
  @@index([tenantId, status])
  @@index([tenantId, categoryId])
  @@index([tenantId, siteId])
  @@index([tenantId, deletedAt])
  @@index([rfidTag])
  @@index([barcode])
  @@map("assets")
}

// ─── Disposals ────────────────────────────────────────────────────────────────
model Disposal {
  id              String   @id @default(cuid())
  tenantId        String
  assetId         String   @unique
  disposalDate    DateTime
  disposalMethod  String
  disposalValue   Decimal? @db.Decimal(12, 2)
  disposalReason  String?
  netBookValueAtDisposal Decimal? @db.Decimal(12, 2)
  gainLoss        Decimal? @db.Decimal(12, 2)
  approvedBy      String?
  notes           String?
  createdBy       String
  createdAt       DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([tenantId])
  @@map("disposals")
}

// ─── Photos ───────────────────────────────────────────────────────────────────
model Photo {
  id                 String   @id @default(cuid())
  tenantId           String
  assetId            String
  maintenanceEventId String?
  storageKey         String   @unique
  thumbStorageKey    String?  @unique
  mimeType           String
  sizeBytes          Int
  width              Int?
  height             Int?
  caption            String?
  createdBy          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  asset       Asset             @relation(fields: [assetId],            references: [id], onDelete: Cascade)
  maintenance MaintenanceEvent? @relation(fields: [maintenanceEventId], references: [id], onDelete: Cascade)

  @@index([tenantId, assetId])
  @@index([tenantId, maintenanceEventId])
  @@map("photos")
}

// ─── Audit Campaigns ─────────────────────────────────────────────────────────
model AuditCampaign {
  id                String   @id @default(cuid())
  tenantId          String
  name              String
  mode              String   @default("sighted")
  siteId            String?
  locationId        String?
  categoryId        String?
  status            String   @default("draft")
  linkedCampaignId  String?
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant              Tenant                    @relation(fields: [tenantId], references: [id])
  linkedCampaign      AuditCampaign?            @relation("DoubleBlink", fields: [linkedCampaignId], references: [id])
  linkedFrom          AuditCampaign[]           @relation("DoubleBlink")
  scanEvents          AuditScanEvent[]
  assets              AuditCampaignAsset[]
  snapshotAssets      AuditSnapshotAsset[]
  zoneSubmissions     AuditZoneSubmission[]
  reconciliationItems AuditReconciliationItem[]
  adjustments         AuditAdjustment[]

  @@index([tenantId, status])
  @@map("audit_campaigns")
}

// Explicit asset-list scope. When rows exist for a campaign, ONLY those
// assets are "expected"; site/location/category scopes are ignored.
model AuditCampaignAsset {
  campaignId String
  assetId    String
  addedAt    DateTime @default(now())

  campaign AuditCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([campaignId, assetId])
  @@index([campaignId])
  @@map("audit_campaign_assets")
}

model AuditScanEvent {
  id         String   @id @default(cuid())
  campaignId String
  tenantId   String
  tagValue   String
  assetId    String?
  scannedBy  String
  deviceId   String?
  locationId String?
  condition  String?
  result     String   @default("found")
  scannedAt  DateTime @default(now())

  campaign            AuditCampaign            @relation(fields: [campaignId], references: [id])
  reconciliationItems AuditReconciliationItem[]

  @@index([campaignId])
  @@index([tenantId, tagValue])
  @@map("audit_scan_events")
}

// ─── Blind Audit: Register Snapshot ──────────────────────────────────────────
model AuditSnapshotAsset {
  id            String   @id @default(cuid())
  campaignId    String
  assetId       String
  assetNumber   String
  name          String
  rfidTag       String?
  barcode       String?
  siteId        String?
  locationId    String?
  categoryId    String?
  condition     String?
  purchaseCost  Decimal? @db.Decimal(12, 2)
  residualValue Decimal? @db.Decimal(12, 2)
  snapshotAt    DateTime @default(now())

  campaign            AuditCampaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reconciliationItems AuditReconciliationItem[]

  @@unique([campaignId, assetId])
  @@index([campaignId])
  @@map("audit_snapshot_assets")
}

// ─── Blind Audit: Zone Submissions ───────────────────────────────────────────
model AuditZoneSubmission {
  id          String   @id @default(cuid())
  campaignId  String
  locationId  String
  submittedBy String
  submittedAt DateTime @default(now())

  campaign AuditCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, locationId])
  @@index([campaignId])
  @@map("audit_zone_submissions")
}

// ─── Blind Audit: Reconciliation Items ───────────────────────────────────────
model AuditReconciliationItem {
  id                 String  @id @default(cuid())
  campaignId         String
  snapshotAssetId    String?
  scanEventId        String?
  classification     String
  snapshotLocationId String?
  foundLocationId    String?
  snapshotCondition  String?
  foundCondition     String?
  notes              String?
  createdAt          DateTime @default(now())

  campaign      AuditCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  snapshotAsset AuditSnapshotAsset? @relation(fields: [snapshotAssetId], references: [id])
  scanEvent     AuditScanEvent?     @relation(fields: [scanEventId], references: [id])
  adjustments   AuditAdjustment[]

  @@index([campaignId, classification])
  @@map("audit_reconciliation_items")
}

// ─── Blind Audit: Adjustments ────────────────────────────────────────────────
model AuditAdjustment {
  id                   String    @id @default(cuid())
  campaignId           String
  reconciliationItemId String
  adjustmentType       String
  fieldChanged         String?
  valueBefore          String?
  valueAfter           String?
  justification        String
  postedBy             String
  postedAt             DateTime  @default(now())
  appliedToRegister    Boolean   @default(false)
  appliedAt            DateTime?

  campaign           AuditCampaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reconciliationItem AuditReconciliationItem @relation(fields: [reconciliationItemId], references: [id])

  @@index([campaignId])
  @@map("audit_adjustments")
}

// ─── Check-in / Check-out ─────────────────────────────────────────────────────
model Checkout {
  id             String    @id @default(cuid())
  tenantId       String
  assetId        String
  custodianId    String
  checkedOutBy   String
  checkedInBy    String?
  expectedReturn DateTime?
  checkedOutAt   DateTime  @default(now())
  checkedInAt    DateTime?
  notes          String?

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  asset     Asset  @relation(fields: [assetId], references: [id])

  @@index([tenantId, assetId])
  @@index([tenantId, custodianId])
  @@index([tenantId, checkedInAt])
  @@map("checkouts")
}

// ─── Documents (generic file attachments per asset) ───────────────────────────
model Document {
  id           String   @id @default(cuid())
  tenantId     String
  assetId      String
  documentType String
  fileName     String
  storageKey   String   @unique
  mimeType     String
  sizeBytes    Int
  notes        String?
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([tenantId, assetId])
  @@map("documents")
}

// ─── Maintenance Events ──────────────────────────────────────────────────────
model MaintenanceEvent {
  id              String    @id @default(cuid())
  tenantId        String
  assetId         String
  maintenanceType String
  vendor          String?
  workOrderNumber String?
  cost            Decimal?  @db.Decimal(12, 2)
  description     String?
  scheduledDate   DateTime?
  completedDate   DateTime?
  status          String    @default("scheduled")
  notes           String?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  asset  Asset   @relation(fields: [assetId], references: [id])
  photos Photo[]

  @@index([tenantId, assetId])
  @@index([tenantId, status])
  @@index([tenantId, status, scheduledDate])
  @@map("maintenance_events")
}

// ─── Alert Subscriptions ──────────────────────────────────────────────────────
model AlertSubscription {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  exceptionType String
  channel       String   @default("email")
  frequency     String   @default("daily")
  active        Boolean  @default(true)
  lastSentAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, userId, exceptionType])
  @@index([tenantId, active])
  @@map("alert_subscriptions")
}

// ─── Webhooks ─────────────────────────────────────────────────────────────────
model Webhook {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  url       String
  events    String[]
  secret    String?
  active    Boolean   @default(true)
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, active])
  @@map("webhooks")
}

// ─── Report Schedules ─────────────────────────────────────────────────────────
model ReportSchedule {
  id             String    @id @default(cuid())
  tenantId       String
  reportType     String
  format         String    @default("csv")
  frequency      String    @default("monthly")
  recipientEmail String
  filters        Json?
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  active         Boolean   @default(true)
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId, active])
  @@map("report_schedules")
}

// ─── Custom Field Definitions ─────────────────────────────────────────────────
model CustomFieldDefinition {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  label       String
  fieldType   String   @default("text")
  required    Boolean  @default(false)
  options     String[]
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, active])
  @@map("custom_field_definitions")
}

// ─── Transfers (location / custodian changes) ─────────────────────────────────
model Transfer {
  id              String   @id @default(cuid())
  tenantId        String
  assetId         String
  fromSiteId      String?
  toSiteId        String?
  fromLocationId  String?
  toLocationId    String?
  fromCustodian   String?
  toCustodian     String?
  transferDate    DateTime @default(now())
  reason          String?
  approvedBy      String?
  createdBy       String
  createdAt       DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([tenantId, assetId])
  @@map("transfers")
}

// ─── Licence Tiers (reference data) ──────────────────────────────────────────
model LicenceTier {
  id             String          @id @default(cuid())
  name           LicenceTierName @unique
  displayName    String
  maxAssets      Int
  baseDevices    Int             @default(1)
  pricePerYear   Decimal         @db.Decimal(10, 2)
  pricePerDevice Decimal         @default(10.00) @db.Decimal(10, 2)
  isPerpetual    Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  licences Licence[]

  @@map("licence_tiers")
}

// ─── Licences ─────────────────────────────────────────────────────────────────
model Licence {
  id                String        @id @default(cuid())
  licenceNumber     String        @unique
  tenantId          String
  tierId            String
  status            LicenceStatus @default(active)
  durationMonths    Int           @default(12)
  activatedAt       DateTime?
  expiresAt         DateTime?
  gracePeriodDays   Int           @default(14)
  expiryWarningDays Int           @default(30)
  paymentConfirmed  Boolean       @default(false)
  paymentConfirmedAt DateTime?
  paymentConfirmedBy String?
  suspendedAt       DateTime?
  suspendedBy       String?
  revokedAt         DateTime?
  revokedBy         String?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  tier        LicenceTier  @relation(fields: [tierId], references: [id])
  deviceSlots DeviceSlot[]
  devices     Device[]

  @@index([tenantId, status])
  @@map("licences")
}

// ─── Devices (registered scanning hardware) ──────────────────────────────────
model Device {
  id           String    @id @default(cuid())
  tenantId     String
  deviceName   String
  deviceType   String    @default("handheld")
  serialNumber String?
  hardwareId   String?
  fingerprint  String?
  userId       String?
  licenceId    String?
  active       Boolean   @default(false)
  activatedAt  DateTime?
  lastSeenAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])
  licence Licence? @relation(fields: [licenceId], references: [id])

  @@unique([tenantId, hardwareId])
  @@unique([tenantId, fingerprint])
  @@index([tenantId, active])
  @@index([userId])
  @@index([licenceId])
  @@map("devices")
}

// ─── Device Slots (paid allowances per licence) ──────────────────────────────
model DeviceSlot {
  id          String   @id @default(cuid())
  licenceId   String
  addedBy     String
  paidAmount  Decimal  @default(10.00) @db.Decimal(10, 2)
  addedAt     DateTime @default(now())

  licence Licence @relation(fields: [licenceId], references: [id])

  @@index([licenceId])
  @@map("device_slots")
}

// ─── Company Registration (tenant's own company) ─────────────────────────────
model Company {
  id                 String   @id @default(cuid())
  tenantId           String   @unique
  legalName          String
  tradingName        String?
  registrationNumber String?
  addressLine1       String
  addressLine2       String?
  city               String
  stateProvince      String?
  postalCode         String?
  country            String
  primaryContactName  String
  primaryContactEmail String
  primaryContactPhone String?
  logoStorageKey     String?
  currency           String   @default("USD")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("companies")
}

// ─── Client Companies (external clients for project work) ────────────────────
model ClientCompany {
  id                 String   @id @default(cuid())
  tenantId           String
  legalName          String
  tradingName        String?
  registrationNumber String?
  addressLine1       String
  addressLine2       String?
  city               String
  stateProvince      String?
  postalCode         String?
  country            String
  primaryContactName  String
  primaryContactEmail String
  primaryContactPhone String?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  authorities ClientAuthority[]

  @@unique([tenantId, legalName])
  @@index([tenantId])
  @@map("client_companies")
}

// ─── Client Authority (engagement signatory contact) ─────────────────────────
model ClientAuthority {
  id              String   @id @default(cuid())
  clientCompanyId String
  name            String
  email           String
  phone           String?
  jobTitle        String?
  isSignatory     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientCompany ClientCompany @relation(fields: [clientCompanyId], references: [id])

  @@index([clientCompanyId])
  @@map("client_authorities")
}

// ─── Onboarding Progress ─────────────────────────────────────────────────────
model OnboardingProgress {
  id          String         @id @default(cuid())
  tenantId    String
  step        OnboardingStep
  completed   Boolean        @default(false)
  completedAt DateTime?
  completedBy String?
  data        Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, step])
  @@index([tenantId])
  @@map("onboarding_progress")
}

// ─── User Invitations ────────────────────────────────────────────────────────
model UserInvitation {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  token     String   @unique
  expiresAt DateTime
  accepted  Boolean  @default(false)
  acceptedAt DateTime?
  createdBy String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([token])
  @@map("user_invitations")
}

// ─── Two-Factor Authentication ───────────────────────────────────────────────
model UserTwoFactor {
  id          String   @id @default(cuid())
  userId      String   @unique
  secret      String
  backupCodes String[]
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_two_factor")
}

// ─── Login Attempts (for progressive lockout) ────────────────────────────────
model LoginAttempt {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  ipAddress String
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

// ─── Mobile Releases (over-the-internet auto-updater) ────────────────────────
model MobileRelease {
  id               String   @id @default(cuid())
  versionCode      Int      @unique
  versionName      String
  storageKey       String
  sizeBytes        Int
  sha256           String
  releaseNotes     String?
  mandatory        Boolean  @default(false)
  isCurrent        Boolean  @default(false)
  uploadedByUserId String?
  uploadedAt       DateTime @default(now())

  @@index([isCurrent])
  @@index([versionCode])
  @@map("mobile_releases")
}

// ─── Platform SMTP Config (singleton row, id = "singleton") ──────────────────
model SmtpConfig {
  id               String    @id @default("singleton")
  provider         String    @default("smtp") // "smtp" | "resend"
  host             String
  port             Int       @default(587)
  secure           Boolean   @default(false)
  username         String?
  passwordEnc      String?
  fromAddress      String
  active           Boolean   @default(true)
  lastVerifiedAt   DateTime?
  lastVerifyError  String?
  updatedAt        DateTime  @updatedAt
  updatedByUserId  String?

  @@map("smtp_config")
}
