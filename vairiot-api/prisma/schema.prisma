generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenants ──────────────────────────────────────────────────────────────────
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("standalone")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  roles       Role[]
  auditEvents AuditEvent[]
  categories  Category[]
  sites       Site[]
  assets      Asset[]
  auditCampaigns AuditCampaign[]
  checkouts   Checkout[]
  apiKeys     ApiKey[]

  @@map("tenants")
}

// ─── API Keys ─────────────────────────────────────────────────────────────────
model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  prefix     String
  hash       String
  scopes     String[]
  createdBy  String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([prefix])
  @@map("api_keys")
}

// ─── Users ────────────────────────────────────────────────────────────────────
model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  name         String
  passwordHash String?
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  roles       UserRole[]
  auditEvents AuditEvent[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ─── Roles ────────────────────────────────────────────────────────────────────
model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  permissions String[]
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id])
  users  UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model UserRole {
  userId    String
  roleId    String
  grantedAt DateTime @default(now())
  grantedBy String?

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

// ─── Audit Events ─────────────────────────────────────────────────────────────
model AuditEvent {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String?
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  metadata   Json?
  occurredAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  actor  User?  @relation(fields: [actorId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, occurredAt])
  @@map("audit_events")
}

// ─── Asset Categories ─────────────────────────────────────────────────────────
model Category {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  parentId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  assets   Asset[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("categories")
}

// ─── Sites & Locations ────────────────────────────────────────────────────────
model Site {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  city      String?
  country   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  locations Location[]
  assets    Asset[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("sites")
}

model Location {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  type      String   @default("room")
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site     Site       @relation(fields: [siteId], references: [id])
  parent   Location?  @relation("LocationChildren", fields: [parentId], references: [id])
  children Location[] @relation("LocationChildren")
  assets   Asset[]

  @@index([siteId])
  @@map("locations")
}

// ─── Assets ───────────────────────────────────────────────────────────────────
model Asset {
  id           String    @id @default(cuid())
  tenantId     String
  assetNumber  String
  name         String
  description  String?
  categoryId   String?
  siteId       String?
  locationId   String?
  status       String    @default("active")
  condition    String    @default("good")
  serialNumber String?
  modelNumber  String?
  manufacturer String?
  barcode      String?
  rfidTag      String?

  // ── Financial: Procurement ──
  purchaseDate       DateTime?
  purchaseCost       Decimal?  @db.Decimal(12, 2)
  supplier           String?
  purchaseOrderNumber String?
  invoiceNumber      String?
  invoiceDate        DateTime?
  receiptDate        DateTime?
  capitalizationDate DateTime?

  // ── Financial: Cost Components ──
  freightCost        Decimal?  @db.Decimal(12, 2)
  installationCost   Decimal?  @db.Decimal(12, 2)
  customsDuties      Decimal?  @db.Decimal(12, 2)
  otherCapitalizedCosts Decimal? @db.Decimal(12, 2)

  // ── Financial: Valuation ──
  residualValue      Decimal?  @db.Decimal(12, 2)

  // ── Depreciation ──
  depreciationMethod String?   @default("straight_line")
  usefulLifeMonths   Int?
  depreciationStartDate DateTime?

  warrantyExpiry DateTime?
  notes        String?
  customFields Json?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  category  Category?  @relation(fields: [categoryId], references: [id])
  site      Site?      @relation(fields: [siteId], references: [id])
  location  Location?  @relation(fields: [locationId], references: [id])
  checkouts         Checkout[]
  photos            Photo[]
  disposal          Disposal?
  documents         Document[]
  maintenanceEvents MaintenanceEvent[]
  transfers         Transfer[]

  @@unique([tenantId, assetNumber])
  @@index([tenantId, status])
  @@index([tenantId, categoryId])
  @@index([tenantId, siteId])
  @@index([rfidTag])
  @@index([barcode])
  @@map("assets")
}

// ─── Disposals ────────────────────────────────────────────────────────────────
model Disposal {
  id              String   @id @default(cuid())
  tenantId        String
  assetId         String   @unique
  disposalDate    DateTime
  disposalMethod  String
  disposalValue   Decimal? @db.Decimal(12, 2)
  disposalReason  String?
  netBookValueAtDisposal Decimal? @db.Decimal(12, 2)
  gainLoss        Decimal? @db.Decimal(12, 2)
  approvedBy      String?
  notes           String?
  createdBy       String
  createdAt       DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([tenantId])
  @@map("disposals")
}

// ─── Photos ───────────────────────────────────────────────────────────────────
model Photo {
  id          String   @id @default(cuid())
  tenantId    String
  assetId     String
  storageKey  String   @unique
  mimeType    String
  sizeBytes   Int
  width       Int?
  height      Int?
  caption     String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([tenantId, assetId])
  @@map("photos")
}

// ─── Audit Campaigns ─────────────────────────────────────────────────────────
model AuditCampaign {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  siteId      String?
  locationId  String?
  status      String   @default("draft")
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  scanEvents AuditScanEvent[]

  @@index([tenantId, status])
  @@map("audit_campaigns")
}

model AuditScanEvent {
  id         String   @id @default(cuid())
  campaignId String
  tenantId   String
  tagValue   String
  assetId    String?
  scannedBy  String
  deviceId   String?
  result     String   @default("found")
  scannedAt  DateTime @default(now())

  campaign AuditCampaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
  @@index([tenantId, tagValue])
  @@map("audit_scan_events")
}

// ─── Check-in / Check-out ─────────────────────────────────────────────────────
model Checkout {
  id             String    @id @default(cuid())
  tenantId       String
  assetId        String
  custodianId    String
  checkedOutBy   String
  checkedInBy    String?
  expectedReturn DateTime?
  checkedOutAt   DateTime  @default(now())
  checkedInAt    DateTime?
  notes          String?

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  asset     Asset  @relation(fields: [assetId], references: [id])

  @@index([tenantId, assetId])
  @@index([tenantId, custodianId])
  @@index([tenantId, checkedInAt])
  @@map("checkouts")
}

// ─── Documents (generic file attachments per asset) ───────────────────────────
model Document {
  id           String   @id @default(cuid())
  tenantId     String
  assetId      String
  documentType String
  fileName     String
  storageKey   String   @unique
  mimeType     String
  sizeBytes    Int
  notes        String?
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([tenantId, assetId])
  @@map("documents")
}

// ─── Maintenance Events ──────────────────────────────────────────────────────
model MaintenanceEvent {
  id              String    @id @default(cuid())
  tenantId        String
  assetId         String
  maintenanceType String
  vendor          String?
  workOrderNumber String?
  cost            Decimal?  @db.Decimal(12, 2)
  description     String?
  scheduledDate   DateTime?
  completedDate   DateTime?
  status          String    @default("scheduled")
  notes           String?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([tenantId, assetId])
  @@index([tenantId, status])
  @@map("maintenance_events")
}

// ─── Alert Subscriptions ──────────────────────────────────────────────────────
model AlertSubscription {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  exceptionType String
  channel       String   @default("email")
  frequency     String   @default("daily")
  active        Boolean  @default(true)
  lastSentAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, userId, exceptionType])
  @@index([tenantId, active])
  @@map("alert_subscriptions")
}

// ─── Webhooks ─────────────────────────────────────────────────────────────────
model Webhook {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  url       String
  events    String[]
  secret    String?
  active    Boolean   @default(true)
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, active])
  @@map("webhooks")
}

// ─── Report Schedules ─────────────────────────────────────────────────────────
model ReportSchedule {
  id             String    @id @default(cuid())
  tenantId       String
  reportType     String
  format         String    @default("csv")
  frequency      String    @default("monthly")
  recipientEmail String
  filters        Json?
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  active         Boolean   @default(true)
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId, active])
  @@map("report_schedules")
}

// ─── Transfers (location / custodian changes) ─────────────────────────────────
model Transfer {
  id              String   @id @default(cuid())
  tenantId        String
  assetId         String
  fromSiteId      String?
  toSiteId        String?
  fromLocationId  String?
  toLocationId    String?
  fromCustodian   String?
  toCustodian     String?
  transferDate    DateTime @default(now())
  reason          String?
  approvedBy      String?
  createdBy       String
  createdAt       DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([tenantId, assetId])
  @@map("transfers")
}
