<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production server now uses a real Let's Encrypt certificate on
         vai.vairiot.com, so the system trust store is sufficient.
         No cleartext traffic anywhere. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
