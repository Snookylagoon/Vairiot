# ─── Deployment mode ──────────────────────────────────────────────────────────
# Options: standalone | saas | hybrid
DEPLOYMENT_MODE=standalone

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://vairiot:changeme@localhost:5432/vairiot_dev"
POSTGRES_USER=vairiot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vairiot_dev

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=3001
API_BASE_URL=http://localhost:3001
JWT_SECRET=replace-with-a-long-random-string-minimum-64-characters
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=30d

# ─── Web app ──────────────────────────────────────────────────────────────────
WEB_PORT=3000
VITE_API_URL=http://81.85.92.155

# ─── File storage (MinIO — S3-compatible) ─────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=vairiot-minio
MINIO_ROOT_PASSWORD=changeme-minio
MINIO_BUCKET=vairiot-documents
MINIO_PHOTOS_BUCKET=vairiot-photos
MINIO_DOCUMENTS_BUCKET=vairiot-documents

# ─── Email (for notifications — optional in standalone) ───────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=changeme
EMAIL_FROM="Vairiot <notifications@example.com>"

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Options: error | warn | info | debug

# ─── SaaS / Hybrid only ───────────────────────────────────────────────────────
# Leave blank for standalone deployments
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_CALLBACK_URL=
